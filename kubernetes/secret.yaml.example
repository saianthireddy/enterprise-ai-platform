apiVersion: v1
kind: Secret
metadata:
  name: eap-secrets
type: Opaque
stringData:
  SECRET_KEY: "replace-with-a-strong-random-value"
  OPENAI_API_KEY: ""
  PINECONE_API_KEY: ""
  DATABASE_URL: "postgresql://eap:REPLACE@eap-db.internal:5432/eap"
  REDIS_URL: "redis://eap-redis.internal:6379/0"
  GOOGLE_OAUTH_CLIENT_ID: ""
  GOOGLE_OAUTH_CLIENT_SECRET: ""
  SLACK_WEBHOOK_URL: ""
# kubectl apply -f secret.yaml (never commit the filled-in version)
